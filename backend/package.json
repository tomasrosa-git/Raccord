{
  "name": "raccord-backend",
  "version": "0.1.0",
  "private": true,
  "description": "API REST de Raccord — plataforma de cine de autor",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
